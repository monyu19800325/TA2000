        public bool AreAllValuesEqual<T>(List<T> list)
        {
            return list.Count == 0 || list.All(x => EqualityComparer<T>.Default.Equals(x, list[0]));
        }



        #region For ProductMeasureTool使用

        public class BoatSettingData
        {
