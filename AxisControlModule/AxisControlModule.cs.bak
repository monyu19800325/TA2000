        #region Axis Initinal

        /// <summary>
        /// Machine初始化時，會執行這段程式
        /// </summary>
        [ModuleInitialFunction(1, -1)]
        public void InitialStep()
        {
           
            LogTrace("InitialStep1 Start");
            LogTrace("InitialStep Start");
            PreGetIMotorOffset();
            PreGetTray();
            IOInitial();
            LogTrace("InitialStep1 IOInitial End");

            bool iniStateCheck = false;
            bool cvIOState = X066003_傳送流道_產品減速檢知.CheckIO() || X066002_傳送流道_產品位置檢知.CheckIO()
                || X066004_傳送流道_產品到位檢知.CheckIO();


            if (cvIOState)
            {
                LogTrace("Initial--流道上有載盤");

                var service = this.GetHtaService<IDialogService>();
                var result = service.ShowDialog(this, new ShowDialogArgs()
                {
                    Button = MessageBoxButtons.YesNo,
                    Message = "是否要同載盤初始化?",
                });


                if (result == DialogResult.Yes) { iniStateCheck = true; }
                else { iniStateCheck = false; }


            }


            if (!cvIOState || iniStateCheck)
            {
             




                視覺縱移軸.SetServoOn(false);
                //AY2_視覺縱移軸_右.SetServoOn(false);
                BX1_流道橫移軸.SetServoOn(false);
                BZ1_流道頂升升降軸.SetServoOn(false);
                BX2_流道傳送軸.Stop();


                Thread.Sleep(200);

                視覺縱移軸.SetServoOn(true);
                //AY2_視覺縱移軸_右.SetServoOn(true);
                BX1_流道橫移軸.SetServoOn(true);
                BZ1_流道頂升升降軸.SetServoOn(true);
                Thread.Sleep(200);

                LogTrace("InitialStep HomeTask Start");
                homeTimeout = 60000;
                var homeTask = new List<Task<bool>>
            {
                //視覺縱移軸 (Go Home)
                //AY2_視覺縱移軸_右
                Task.Factory.StartNew(() =>
                {
                    LogTrace("InitialStep 視覺縱移軸 Home Start");
                    var rlt = 視覺縱移軸.Home(homeTimeout);

                    if(rlt == false)
                        AxisHomeErrorLog(視覺縱移軸);

                    LogTrace($@"Initial 視覺縱移軸 Home {rlt}");
                    return rlt;
                }),
                //BZ1_流道頂升升降軸 (Go Home)
                Task.Factory.StartNew(() =>
                {
                    LogTrace("InitialStep BZ1_流道頂升升降軸 Home Start");
                    var rlt = BZ1_流道頂升升降軸.Home(homeTimeout);

                    if(rlt == false)
                        AxisHomeErrorLog(BZ1_流道頂升升降軸);

                    LogTrace($@"InitialStep1 BZ1_流道頂升升降軸 Home {rlt}");
                    return rlt;
                }),
                //BX1_流道橫移軸 (Go Home)
                Task.Factory.StartNew(() =>
                {
                    LogTrace("InitialStep BX1_流道橫移軸 Home Start");
                    var rlt = BX1_流道橫移軸.Home(homeTimeout);

                    if(rlt == false)
                        AxisHomeErrorLog(BX1_流道橫移軸);

                    LogTrace($@"InitialStep1 BX1_流道橫移軸 Home {rlt}");
                    return rlt;
                }),

            };


                Task.WaitAll(homeTask.ToArray());
                bool bHT = true;
                foreach (var task in homeTask)
                {
                    if (!task.Result)
                    {
                        bHT = task.Result;
                        AddTrace?.Invoke("UA_AxisControlModule", task.ToString() + task.Result.ToString());
                        break;
                    }
                    //if (task.Status != TaskStatus.RanToCompletion || task.Result == false)
                    //    throw new Exception($@"InitialStep1 Failed");
                }

                LogTrace("InitialStep1 End");
            }
            else
            {
                var service = this.GetHtaService<IDialogService>();

                var result = service.ShowDialog(this, new ShowDialogArgs()
                {
                    Button = MessageBoxButtons.OK,
                    Message = "請手動移出載盤再初始化",
                });
                if (result != DialogResult.OK)
                {
                    throw new Exception($@"InitialStep Failed");
                }
                    
            }


        }

       
        public void IOInitial()
        {
            
            Y065003_正壓源電磁閥.SetIO(true);
            Y067000_傳送流道_靠邊氣缸電磁閥.SetIO(false);
            Y067001_傳送流道_到位氣缸電磁閥.SetIO(false);
            Y067002_傳送流道_頂升真空電磁閥.SetIO(false);
            Y067013_靜電消除器_放電啟動.SetIO(true);
            SpinWait.SpinUntil(() => false, 1000);

            if (X064010_正壓源檢知 is VirtualInputIO)
            {
                return;
            }

            if (!X064010_正壓源檢知.CheckIO())
            {
                throw new Exception("X064010_正壓源檢知 正壓源未產生，請確認");
            }

            if (X066005_傳送流道_到位氣缸_上升.CheckIO() || !X066006_傳送流道_到位氣缸_下降.CheckIO())
            {
                throw new Exception("到位氣缸現在為異常的狀態，請確認並將其下降");
            }

            //if (X066007_治具頂升氣缸_上升.CheckIO() || !X066008_治具頂升氣缸_下降.CheckIO())
            //{
            //    throw new Exception("治具頂升氣缸現在為異常的狀態，請確認並將其下降");
            //}

            if (X066000_傳送流道_入料銜接檢知_上下對照.CheckIO() || X066007_傳送流道_出料銜接檢知_側邊反射.CheckIO())
            {
                throw new Exception("流道銜接檢知現在為異常的狀態，請確認並將其排除");
            }

           

        }

       


        #endregion

    }
