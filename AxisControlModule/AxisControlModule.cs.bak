        #region Define Interference (軸干涉判斷)



        public void BZ1軸干涉(object sender, FetchExamineAxisArgs args)
        {
            if (args.AxisMoveMode == AxisMoveModeEm.Move)
            {
                //Move
                
                if (X066000_傳送流道_入料銜接檢知_上下對照.CheckIO() || X066007_傳送流道_出料銜接檢知_側邊反射.CheckIO() || X066008_傳送流道_出料銜接檢知_上下對照.CheckIO())
                {
                    args.SetFetchExamine(true);
                    args.FetchExamineString = "流道銜接檢知現在為異常的狀態，請確認並將其排除 ";
                }
                
            }
            else
            {
                //Home
                if (X066000_傳送流道_入料銜接檢知_上下對照.CheckIO() || X066007_傳送流道_出料銜接檢知_側邊反射.CheckIO() || X066008_傳送流道_出料銜接檢知_上下對照.CheckIO())
                {
                    args.SetFetchExamine(true);
                    args.FetchExamineString= "流道銜接檢知現在為異常的狀態，請確認並將其排除 ";
                }
            }
        }
        public void BX1軸干涉(object sender, FetchExamineAxisArgs args)
        {

            //2.BZ1不能在頂升位置

            if (args.AxisMoveMode == AxisMoveModeEm.Move)
            {
                //Move
                if (BZ1_流道頂升升降軸.ActualPos >= _inspectMotorOffset.Start_Z1)
                {
                    args.SetFetchExamine(true);
                }



            }
            else if (args.AxisMoveMode == AxisMoveModeEm.Home)
            {

                if (BZ1_流道頂升升降軸.ActualPos >= _inspectMotorOffset.Start_Z1)
                {
                    args.SetFetchExamine(true);
                }
            }
            else
            {

            }
        }


        public void BZ1流道頂升升降軸干涉(object sender, FetchExamineAxisArgs args)
        {

            if (X066000_傳送流道_入料銜接檢知_上下對照.CheckIO() || X066001_傳送流道_入料銜接檢知_側邊反射.CheckIO() ||
                X066007_傳送流道_出料銜接檢知_側邊反射.CheckIO() || X066008_傳送流道_出料銜接檢知_上下對照.CheckIO())
            {
                args.SetFetchExamine(true);
                args.FetchExamineString = "流道銜接檢知現在為異常的狀態，請確認並將其排除 ";
                //MessageBox.Show("流道銜接檢知現在為異常的狀態，請確認並將其排除 ");
            }

        }


