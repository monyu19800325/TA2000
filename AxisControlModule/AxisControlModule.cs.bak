        #region Define Broadcast Receive

        [DefineBroadcastReceive]
        public void GetMotorST(object sender, MotorSTArgs args)
        {
            //執行前，如果有進過ST，就要ServoOff、ServoOn
            視覺縱移軸.SetServoOn(false);
            //AY2_視覺縱移軸_右.SetServoOn(false);
            BX1_流道橫移軸.SetServoOn(false);
            BZ1_流道頂升升降軸.SetServoOn(false);
            BX2_流道傳送軸.Stop();


            Thread.Sleep(50);

            視覺縱移軸.SetServoOn(true);
            //AY2_視覺縱移軸_右.SetServoOn(true);
            BX1_流道橫移軸.SetServoOn(true);
            BZ1_流道頂升升降軸.SetServoOn(true);
           


            Thread.Sleep(1000);//等待ServoOn完成
        }

        [DefineBroadcastReceive]
        public void GetInital(object sender, InitalArgs args)
        {
            IsInitalAxis = args.IsInitialAxis;
        }

        #endregion

        #region Funtion

        public void LogTrace(string msg)
        {
            AddTrace?.Invoke("AxisControlModule", $@"{msg}");
            string timeStr = DateTime.Now.ToString("HH:mm:ss") + " : ";
            _showWorkLogService?.AddWorkLog(this, timeStr + msg);
        }

        public void AxisHomeErrorLog(IAxis axis)
        {
            LogTrace($"HomeFailed - Axis:{axis.Name}, ALM:{axis.CurrentStatus.ALM}, INP:{axis.CurrentStatus.INP}, SVON:{axis.CurrentStatus.SVON}, EMG:{axis.CurrentStatus.EMG}, NSTP:{axis.CurrentMoveStatus.NSTP}, CSTP:{axis.CurrentMoveStatus.CSTP}");
            LogTrace($"MoveAxisFailed - ErrorCode:{axis.ErrorCode.ToString()}, Message{axis.ErrorString}");
        }



        public void PreGetTray()
        {
            _carrier = new BoatCarrier();
            _carrier.IsPreUse = true;
            _carrier.IsCalBig = false;
            GetTrayLayout?.Invoke(this, _carrier);
        }







