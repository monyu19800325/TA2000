        public void PreGetIMotorOffset()
        {
            _inspectMotorOffset = new MotorOffsetParam();
            _flowMotorOffset = new FlowMotorOffset();


            MotorOffsetParam args = new MotorOffsetParam();
            //觸發事件，並寫入_IMotorOffset InspectionParamArgs
            GetIMotorOffset?.Invoke(this, _inspectMotorOffset);
            GetFMotorOffset?.Invoke(this, _flowMotorOffset);
         
        }


        public AdLinkEtherCatAxis Y_EtherCATInstance => 視覺縱移軸 is AdLinkEtherCatAxis etherCatAxis ? etherCatAxis : null;
        public AdLinkEtherCatAxis X_EtherCATInstance => BX1_流道橫移軸 is AdLinkEtherCatAxis etherCatAxis ? etherCatAxis : null;




