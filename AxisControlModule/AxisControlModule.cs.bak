        /// <summary>
        /// Axis set "0" pos (ABS)
        /// </summary>
        public override void MachineControllerReady()
        {
            base.MachineControllerReady();
            _MachineStateArgs._AxisState = SetVirtualIO() ? AxisState.Virtual: AxisState.Real;
            NotifyAxisIsVirtual?.Invoke(this, _MachineStateArgs);

            if (true)
            {
                if (BZ1_流道頂升升降軸.GetEncoderType() == AxisEncoderTypeEm.絕對型)
                {
                    BZ1_流道頂升升降軸.SetAbosoluteZeroPos(0);

                }
                if (BX1_流道橫移軸.GetEncoderType() == AxisEncoderTypeEm.絕對型)
                {
                    BX1_流道橫移軸.SetAbosoluteZeroPos(0);

                }
            }
           


        }
        public bool SetVirtualIO()
        {
            bool _bVirtual = false;
            if (BZ1_流道頂升升降軸 is HTA.Motion3.Virtual.VirtualAxis || BX1_流道橫移軸 is HTA.Motion3.Virtual.VirtualAxis || 視覺縱移軸 is HTA.Motion3.Virtual.VirtualAxis )
            {
                _bVirtual = true;

                X066000_傳送流道_入料銜接檢知_上下對照.SetIO(false);
                X066007_傳送流道_出料銜接檢知_側邊反射.SetIO(false);
                X066003_傳送流道_產品減速檢知.SetIO(false);
                X066004_傳送流道_產品到位檢知.SetIO(false);
                X066002_傳送流道_產品位置檢知.SetIO(false);

            }
            return _bVirtual;
        }


